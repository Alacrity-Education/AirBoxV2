    {
      "id": 12,
      "type": "table",
      "title": "Latest reading per device",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "datasource": {
        "type": "postgres",
        "uid": "airbox-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "format": "table",
          "rawSql": "SELECT DISTINCT ON (r.device) r.device, r.\"time\" AS last_seen, r.installation, i.owner_email, r.geohash, r.charge, r.pm25, r.temp, r.hum, r.co2, r.voc_index, r.nox_index FROM airbox_readings r LEFT JOIN airbox_installations i ON i.device_id = r.device WHERE r.device IN (${device:sqlstring}) ORDER BY r.device, r.\"time\" DESC"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
