  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Station dashboard",
      "transparent": true,
      "gridPos": {
        "h": 4,
        "w": 18,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "airbox-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "format": "table",
          "rawSql": "SELECT i.device_id AS \"Station ID\", COALESCE(NULLIF(i.notes, ''), '—') AS \"Name\", i.installation AS \"Installation\", i.owner_email AS \"Owner\", COALESCE(r.geohash, '—') AS \"Location (geohash)\" FROM airbox_installations i LEFT JOIN LATERAL (SELECT geohash FROM airbox_readings x WHERE x.device = i.device_id ORDER BY x.\"time\" DESC LIMIT 1) r ON true WHERE i.device_id = ${device:sqlstring}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 2,
      "type": "text",
      "title": "",
      "transparent": true,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "# 🌀 AirBox\n**Air monitoring station**"
      }
    },
    {
      "id": 3,
      "type": "table",
      "title": "🟣 Recommendations (based on the last hour average)",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "airbox-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "format": "table",
          "rawSql": "WITH ultima_ora AS (SELECT avg(pm25) AS pm25, avg(pm10) AS pm10, avg(co2) AS co2, avg(voc_index) AS voc, avg(nox_index) AS nox, avg(hum) AS hum FROM airbox_readings WHERE device = ${device:sqlstring} AND \"time\" > now() - interval '1 hour'), recomandari AS (SELECT unnest(ARRAY[CASE WHEN co2 > 1000 THEN 'High CO2 (' || round(co2) || ' ppm): ventilate the room — open the window for 5–10 minutes.' END, CASE WHEN pm25 > 35 THEN 'High PM2.5 (' || round(pm25) || ' µg/m³): close the windows if the pollution comes from outside or turn on a purifier with a HEPA filter.' END, CASE WHEN pm10 > 100 THEN 'High PM10 (' || round(pm10) || ' µg/m³): avoid activities that raise dust; wipe surfaces with a damp cloth.' END, CASE WHEN voc > 250 THEN 'High VOC index (' || round(voc) || '): ventilate and check the sources of volatile compounds (cleaning, paint, cooking).' END, CASE WHEN nox > 250 THEN 'High NOx index (' || round(nox) || '): possible combustion gases — check the stove/boiler and ventilate.' END, CASE WHEN hum > 65 THEN 'High humidity (' || round(hum) || '%): mold risk — ventilate or use a dehumidifier.' END, CASE WHEN hum < 30 THEN 'Low humidity (' || round(hum) || '%): dry air — use a humidifier.' END]) AS \"Recommendation\" FROM ultima_ora) SELECT \"Recommendation\" FROM recomandari WHERE \"Recommendation\" IS NOT NULL UNION ALL SELECT 'The air looks good — no action needed ✅' WHERE NOT EXISTS (SELECT 1 FROM recomandari WHERE \"Recommendation\" IS NOT NULL)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "IAQ index (last hour)",
      "description": "Simplified air quality index: the worst sub-score among PM2.5, PM10, CO₂, VOC and NOx, normalized to 0–100+. 0–50 = Good, 50–100 = Moderate, over 100 = Unhealthy. Provisional formula — to be replaced with the official IAQ formula once defined.",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "postgres",
        "uid": "airbox-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "format": "table",
          "rawSql": "SELECT round(GREATEST(avg(pm25)/75.0*100, avg(pm10)/150.0*100, (avg(co2)-400)/16.0, avg(voc_index)/5.0, avg(nox_index)/5.0)) AS \"IAQ\" FROM airbox_readings WHERE device = ${device:sqlstring} AND \"time\" > now() - interval '1 hour'"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "#EAB839",
                "value": 50
              },
              {
                "color": "orange",
                "value": 75
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
