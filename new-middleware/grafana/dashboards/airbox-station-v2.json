    {
      "id": 1,
      "type": "table",
      "title": "Dashboard Statie",
      "transparent": true,
      "gridPos": {
        "h": 4,
        "w": 18,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "airbox-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "format": "table",
          "rawSql": "SELECT i.device_id AS \"ID statie\", COALESCE(NULLIF(i.notes, ''), '—') AS \"Nume conventional\", i.installation AS \"Instalare\", i.owner_email AS \"Proprietar\", COALESCE(r.geohash, '—') AS \"Locatie (geohash)\" FROM airbox_installations i LEFT JOIN LATERAL (SELECT geohash FROM airbox_readings x WHERE x.device = i.device_id ORDER BY x.\"time\" DESC LIMIT 1) r ON true WHERE i.device_id = ${device:sqlstring}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 2,
      "type": "text",
      "title": "",
      "transparent": true,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "# 🌀 AirBox\n**Statie de monitorizare a aerului**"
      }
    },
    {
      "id": 3,
      "type": "table",
      "title": "🟣 Recomandari (pe baza mediei din ultima ora)",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "airbox-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "format": "table",
          "rawSql": "WITH ultima_ora AS (SELECT avg(pm25) AS pm25, avg(pm10) AS pm10, avg(co2) AS co2, avg(voc_index) AS voc, avg(nox_index) AS nox, avg(hum) AS hum FROM airbox_readings WHERE device = ${device:sqlstring} AND \"time\" > now() - interval '1 hour'), recomandari AS (SELECT unnest(ARRAY[CASE WHEN co2 > 1000 THEN 'CO2 ridicat (' || round(co2) || ' ppm): aeriseste incaperea — deschide geamul 5–10 minute.' END, CASE WHEN pm25 > 35 THEN 'PM2.5 ridicat (' || round(pm25) || ' µg/m³): inchide geamurile daca poluarea vine de afara sau porneste un purificator cu filtru HEPA.' END, CASE WHEN pm10 > 100 THEN 'PM10 ridicat (' || round(pm10) || ' µg/m³): evita activitatile care ridica praf; sterge suprafetele cu laveta umeda.' END, CASE WHEN voc > 250 THEN 'Indice VOC ridicat (' || round(voc) || '): aeriseste si verifica sursele de compusi volatili (curatenie, vopsea, gatit).' END, CASE WHEN nox > 250 THEN 'Indice NOx ridicat (' || round(nox) || '): posibile gaze de ardere — verifica aragazul/centrala si aeriseste.' END, CASE WHEN hum > 65 THEN 'Umiditate mare (' || round(hum) || '%): risc de mucegai — aeriseste sau foloseste un dezumidificator.' END, CASE WHEN hum < 30 THEN 'Umiditate scazuta (' || round(hum) || '%): aer uscat — foloseste un umidificator.' END]) AS \"Recomandare\" FROM ultima_ora) SELECT \"Recomandare\" FROM recomandari WHERE \"Recomandare\" IS NOT NULL UNION ALL SELECT 'Aerul arata bine — nicio actiune necesara ✅' WHERE NOT EXISTS (SELECT 1 FROM recomandari WHERE \"Recomandare\" IS NOT NULL)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Indice IAQ (ultima ora)",
      "description": "Indice simplificat al calitatii aerului: cel mai slab sub-scor dintre PM2.5, PM10, CO₂, VOC si NOx, normalizat 0–100+. 0–50 = Bun, 50–100 = Moderat, peste 100 = Nesanatos. Formula provizorie — de inlocuit cu formula IAQ oficiala cand este definita.",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "postgres",
        "uid": "airbox-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "format": "table",
          "rawSql": "SELECT round(GREATEST(avg(pm25)/75.0*100, avg(pm10)/150.0*100, (avg(co2)-400)/16.0, avg(voc_index)/5.0, avg(nox_index)/5.0)) AS \"IAQ\" FROM airbox_readings WHERE device = ${device:sqlstring} AND \"time\" > now() - interval '1 hour'"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "#EAB839",
                "value": 50
              },
              {
                "color": "orange",
                "value": 75
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
