    {
      "id": 100,
      "type": "table",
      "title": "Station dashboard",
      "transparent": true,
      "gridPos": {
        "h": 4,
        "w": 18,
        "x": 0,
        "y": 29
      },
      "datasource": {
        "type": "postgres",
        "uid": "airbox-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "format": "table",
          "rawSql": "SELECT i.device_id AS \"Station ID\", COALESCE(NULLIF(i.notes, ''), '—') AS \"Name\", i.installation AS \"Installation\", i.owner_email AS \"Owner\", COALESCE(r.geohash, '—') AS \"Location (geohash)\" FROM airbox_installations i LEFT JOIN LATERAL (SELECT geohash FROM airbox_readings x WHERE x.device = i.device_id ORDER BY x.\"time\" DESC LIMIT 1) r ON true WHERE i.device_id = ${device:sqlstring}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
