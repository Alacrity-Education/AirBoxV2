        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT round(GREATEST(avg(pm25)/75.0*100, avg(pm10)/150.0*100, (avg(co2)-400)/16.0, avg(voc_index)/5.0, avg(nox_index)/5.0)) AS \"IAQ\" FROM airbox_readings WHERE device = ${device:sqlstring} AND \"time\" > now() - interval '1 hour'",
