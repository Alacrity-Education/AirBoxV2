      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "airbox-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT DISTINCT ON (r.device)\r\nr.device,\r\nr.geohash,\r\nr.pm10 AS \"Value\",\r\n'/public-dashboards/' || a.slug AS url_statie\r\nFROM airbox_readings r\r\nLEFT JOIN airbox_grafana_artifacts a\r\n  ON a.device_id = r.device AND a.view = 'station'\r\nWHERE $__timeFilter(r.time)\r\nORDER BY r.device, r.time DESC",
          "refId": "A",
