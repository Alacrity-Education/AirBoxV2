      "pluginVersion": "12.0.2",
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH \r\nultima_ora AS (\r\n  SELECT \r\n    avg(pm25) AS pm25, \r\n    avg(pm10) AS pm10, \r\n    avg(co2) AS co2, \r\n    avg(voc_index) AS voc, \r\n    avg(nox_index) AS nox, \r\n    avg(hum) AS hum \r\n    FROM airbox_readings WHERE device = ${device:sqlstring} AND \"time\" > now() - interval '1 hour'), \r\n    recomandari AS (\r\n      SELECT unnest(\r\n        ARRAY[\r\n          CASE WHEN co2 > 1000 THEN 'CO2 ridicat (' || round(co2) || ' ppm): aeriseste incaperea — deschide geamul 5–10 minute.' END, \r\n          CASE WHEN pm25 > 35 THEN 'PM2.5 ridicat (' || round(pm25) || ' µg/m³): inchide geamurile daca poluarea vine de afara sau porneste un purificator cu filtru HEPA.' END, \r\n          CASE WHEN pm10 > 100 THEN 'PM10 ridicat (' || round(pm10) || ' µg/m³): evita activitatile care ridica praf; sterge suprafetele cu laveta umeda.' END, \r\n          CASE WHEN voc > 250 THEN 'Indice VOC ridicat (' || round(voc) || '): aeriseste si verifica sursele de compusi volatili (curatenie, vopsea, gatit).' END, \r\n          CASE WHEN nox > 250 THEN 'Indice NOx ridicat (' || round(nox) || '): posibile gaze de ardere — verifica aragazul/centrala si aeriseste.' END, \r\n          CASE WHEN hum > 65 THEN 'Umiditate mare (' || round(hum) || '%): risc de mucegai — aeriseste sau foloseste un dezumidificator.' END, \r\n          CASE WHEN hum < 30 THEN 'Umiditate scazuta (' || round(hum) || '%): aer uscat — foloseste un umidificator.' END\r\n        ]) \r\n        AS \"Recomandare\" FROM ultima_ora\r\n        ) \r\n        SELECT \"Recomandare\" FROM recomandari WHERE \"Recomandare\" IS NOT NULL UNION ALL SELECT 'Aerul arata bine — nicio actiune necesara ✅' \r\n        WHERE NOT EXISTS (SELECT 1 FROM recomandari WHERE \"Recomandare\" IS NOT NULL\r\n        )",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Recomandari (pe baza mediei din ultima ora)",
      "type": "table"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "airbox-postgres"
      },
      "description": "Indice simplificat al calitatii aerului: cel mai slab sub-scor dintre PM2.5, PM10, CO₂, VOC si NOx, normalizat 0–100+. 0–50 = Bun, 50–100 = Moderat, peste 100 = Nesanatos. Formula provizorie — de inlocuit cu formula IAQ oficiala cand este definita.",
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "mappings": [],
