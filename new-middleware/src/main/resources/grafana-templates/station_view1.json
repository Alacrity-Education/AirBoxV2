        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \r\n\r\ni.device_id                        AS \"ID statie\", \r\nCOALESCE(NULLIF(i.notes, ''), '—') AS \"Nume conventional\", \r\nCOALESCE(r.geohash, '—')           AS \"Locatie (geohash)\" \r\n\r\nFROM airbox_installations i LEFT JOIN LATERAL (\r\n  SELECT geohash \r\n  FROM airbox_readings x \r\n  WHERE x.device = i.device_id ORDER BY x.\"time\" DESC LIMIT 1\r\n  ) r \r\nON true WHERE i.device_id = ${device:sqlstring}",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
