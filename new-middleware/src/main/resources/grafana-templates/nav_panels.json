[
  {
    "id": 9001,
    "type": "table",
    "title": "Navigare",
    "datasource": { "type": "postgres", "uid": "airbox-postgres" },
    "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
    "targets": [
      {
        "refId": "A",
        "datasource": { "type": "postgres", "uid": "airbox-postgres" },
        "rawQuery": true,
        "format": "table",
        "rawSql": "SELECT CASE view WHEN 'harta' THEN 'Harta statii' ELSE 'Vedere generala' END AS \"Vederi\", '/public-dashboards/' || access_token AS url FROM airbox_grafana_artifacts WHERE view IN ('harta','overview') ORDER BY view"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "custom": { "align": "left", "filterable": false }
      },
      "overrides": [
        {
          "matcher": { "id": "byName", "options": "Vederi" },
          "properties": [
            {
              "id": "links",
              "value": [ { "title": "Deschide", "url": "${__data.fields.url}", "targetBlank": true } ]
            }
          ]
        },
        {
          "matcher": { "id": "byName", "options": "url" },
          "properties": [ { "id": "custom.hidden", "value": true } ]
        }
      ]
    },
    "options": { "showHeader": true }
  },
  {
    "id": 9002,
    "type": "table",
    "title": "Statii",
    "datasource": { "type": "postgres", "uid": "airbox-postgres" },
    "gridPos": { "h": 5, "w": 18, "x": 6, "y": 0 },
    "targets": [
      {
        "refId": "A",
        "datasource": { "type": "postgres", "uid": "airbox-postgres" },
        "rawQuery": true,
        "format": "table",
        "rawSql": "SELECT v1.device_id AS \"Statie\", COALESCE(NULLIF(i.notes,''), v1.device_id) AS \"Nume conventional\", 'vedere' AS \"Vedere\", 'detalii' AS \"Detalii\", '/public-dashboards/' || v1.access_token AS url_v1, '/public-dashboards/' || v2.access_token AS url_v2 FROM airbox_grafana_artifacts v1 LEFT JOIN airbox_grafana_artifacts v2 ON v2.device_id = v1.device_id AND v2.view = 'statie_v2' LEFT JOIN airbox_installations i ON i.device_id = v1.device_id WHERE v1.view = 'statie_v1' ORDER BY 2"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "custom": { "align": "left", "filterable": true }
      },
      "overrides": [
        {
          "matcher": { "id": "byName", "options": "Vedere" },
          "properties": [
            {
              "id": "links",
              "value": [ { "title": "Vedere statie", "url": "${__data.fields.url_v1}", "targetBlank": true } ]
            }
          ]
        },
        {
          "matcher": { "id": "byName", "options": "Detalii" },
          "properties": [
            {
              "id": "links",
              "value": [ { "title": "Detalii statie", "url": "${__data.fields.url_v2}", "targetBlank": true } ]
            }
          ]
        },
        {
          "matcher": { "id": "byName", "options": "url_v1" },
          "properties": [ { "id": "custom.hidden", "value": true } ]
        },
        {
          "matcher": { "id": "byName", "options": "url_v2" },
          "properties": [ { "id": "custom.hidden", "value": true } ]
        }
      ]
    },
    "options": { "showHeader": true }
  }
]
