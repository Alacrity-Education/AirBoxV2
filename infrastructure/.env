AIRBOX_USER=1000
AIRBOX_DATA_PATH=/var/alacrity

# =============================================================================
# AIRBOX_MOCKS_ENABLED — the ONE deployment switch for mock (test) installations.
#   true  = testing mode: mock installations seeded into the DB + mock container runs.
#   false = production mode: no mock installations seeded, mock container NOT started.
# Values are lowercase only ("true"/"false") — they are matched literally as a compose
# profile name and passed through to Flyway; anything else silently breaks the switch.
#
# Takes effect on `docker compose up -d`. Two caveats:
#  - When flipping to false on a live system, the already-running mock container is NOT
#    auto-removed (profile-disabled services just stop being managed). Remove it with:
#        docker compose rm -sf mock
#  - The seed decision is made when the V3 migration FIRST runs on a fresh database.
#    Flipping the switch later does NOT retroactively add/remove installations — that
#    needs a DB re-init or manual SQL. This is a deployment-time switch, not a live toggle.
AIRBOX_MOCKS_ENABLED=true

# Fixed machinery for the switch above — DO NOT EDIT. A compose profile literally named
# "true" is active only because the mock service's interpolated profile name equals it
# when AIRBOX_MOCKS_ENABLED=true. The only knob is AIRBOX_MOCKS_ENABLED.
COMPOSE_PROFILES=true

GRAFANA_ADMIN_PASSWORD=CHANGE-ME

TSDB_DATABASE=airbox
TSDB_USER=airbox
TSDB_PASSWORD=CHANGE-ME

GRAFANA_DOMAIN=https://airbox.alacrity.ro
INGEST_DOMAIN=https://ingest.airbox.alacrity.ro

GRAFANA_OIDC_ENABLED=true
GRAFANA_OIDC_CLIENT_ID=CHANGE-ME
GRAFANA_OIDC_CLIENT_SECRET=CHANGE-ME
GRAFANA_OIDC_AUTH_URL=https://auth.alacrity.ro/application/o/authorize/
GRAFANA_OIDC_TOKEN_URL=https://auth.alacrity.ro/application/o/token/
GRAFANA_OIDC_API_URL=https://auth.alacrity.ro/application/o/userinfo/
GRAFANA_OIDC_SCOPES=openid email profile groups

MDW_SERVER_PORT=8080

AIRBOX_ENDPOINT=http://middleware:8080/api/v2/submit
AIRBOX_API_KEYS=mockkey-3f9a1c2b8e7d4056,mockkey-7b2e5f0a9c1d3468,mockkey-a1c4d8e2f6b09357,mockkey-9d0f3a7c1e5b2864
AIRBOX_GEOHASHES=sxft17ek,sxfscg0b,sxfsd565,sxfs8jdh
AIRBOX_INTERVAL_SECONDS=10
AIRBOX_REQUEST_COUNT=0
AIRBOX_AUTH_STYLE=random
MDW_PUBLIC_TOKEN_SECRET=CHANGE-ME
GRAFANA_PLUGINS=volkovlabs-form-panel
