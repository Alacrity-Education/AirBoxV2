  {
    "id": 9002,
    "type": "table",
    "title": "Stations",
    "datasource": { "type": "postgres", "uid": "airbox-postgres" },
    "gridPos": { "h": 5, "w": 18, "x": 6, "y": 0 },
    "targets": [
      {
        "refId": "A",
        "datasource": { "type": "postgres", "uid": "airbox-postgres" },
        "rawQuery": true,
        "format": "table",
        "rawSql": "SELECT v1.device_id AS \"Station\", COALESCE(NULLIF(i.notes,''), v1.device_id) AS \"Name\", 'Station' AS \"View\", '/public-dashboards/' || v1.slug AS url FROM airbox_grafana_artifacts v1 LEFT JOIN airbox_installations i ON i.device_id = v1.device_id WHERE v1.view = 'station' ORDER BY 2"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "custom": { "align": "left", "filterable": true }
      },
      "overrides": [
        {
          "matcher": { "id": "byName", "options": "View" },
          "properties": [
            {
              "id": "links",
              "value": [ { "title": "Open station", "url": "${__data.fields.url}", "targetBlank": true } ]
            }
          ]
        },
        {
          "matcher": { "id": "byName", "options": "url" },
          "properties": [ { "id": "custom.hidden", "value": true } ]
        }
      ]
    },
    "options": { "showHeader": true }
  }
]
